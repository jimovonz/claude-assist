# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Cairn memory system (optional)
CAIRN_DIR=              # Path to cairn repo (default: ~/Projects/cairn)
CAIRN_PYTHON=           # Path to cairn's Python (default: $CAIRN_DIR/.venv/bin/python3)

# View server (optional)
VIEW_PORT=8099          # Port for view server
VIEW_BASE_URL=          # Cloudflare Tunnel URL for view links

# Cloudflare Tunnel (optional — for exposing views to the internet)
CLOUDFLARE_TUNNEL_TOKEN=  # From: cloudflared tunnel create claude-assist

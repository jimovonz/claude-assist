# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Telegram owner ID — receives restart notifications (optional)
TELEGRAM_OWNER_ID=

# Cairn memory system (optional)
CAIRN_DIR=              # Path to cairn repo (default: ~/Projects/cairn)
CAIRN_PYTHON=           # Path to cairn's Python (default: $CAIRN_DIR/.venv/bin/python3)

# View server (optional)
VIEW_PORT=8099          # Port for view server
VIEW_BASE_URL=          # Base URL for view links (default: http://localhost:VIEW_PORT)

# GCE edge server for remote access and view hosting (optional)
EDGE_URL=               # e.g. https://conduit.alimento.co.nz
EDGE_API_SECRET=        # Bearer token for edge API authentication

# TUI client (optional — token for WebSocket authentication)
TUI_AUTH_TOKEN=           # If set, TUI clients must authenticate with this token

# Cloudflare Tunnel (optional — for exposing views to the internet)
CLOUDFLARE_TUNNEL_TOKEN=  # From: cloudflared tunnel create claude-assist
